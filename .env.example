# Paste these into the Django/web service Variables tab on Railway.
# If your database service is not named "Postgres", replace Postgres below
# with the exact Railway service name, for example PostgreSQL.DATABASE_URL.
SECRET_KEY=change-me-to-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=${{RAILWAY_PUBLIC_DOMAIN}}
CSRF_TRUSTED_ORIGINS=https://${{RAILWAY_PUBLIC_DOMAIN}}
DATABASE_URL=${{Postgres.DATABASE_URL}}
